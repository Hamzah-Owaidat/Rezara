# Public site origin, used for metadata/sitemap absolute URLs
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Server-only: base URL of the backend API. Never prefix with NEXT_PUBLIC_ —
# read only by Server Components and Route Handlers, never bundled to the client.
BACKEND_API_URL=http://localhost:4000/api/v1

# Public: origin that serves uploaded media, used by next.config.ts
# images.remotePatterns and by client-rendered next/image.
NEXT_PUBLIC_MEDIA_ORIGIN=http://localhost:4000
