NODE_ENV=development
PORT=4000

# mysql://<user>:<password>@<host>:3306/<database>
DATABASE_URL="mysql://root:@localhost:3306/Rezara"

# Any long random string in dev; use a securely generated secret in staging/production
JWT_SECRET="change-me"
JWT_EXPIRES_IN="8h"

# Origin of the frontend allowed to call this API
CORS_ORIGIN="http://localhost:3000"

# Optional: used by `npm run prisma:seed` to create the first admin account
SEED_ADMIN_EMAIL="admin@rezara.local"
SEED_ADMIN_PASSWORD="ChangeMe123!"
